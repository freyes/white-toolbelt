#!/bin/bash -e

print_usage() {
	cat <<'EOF'
Usage: lxd-launch-with-dirs.sh [--vm] [-t TYPE|--type TYPE] [-c N|--cpus N] [-m N|--mem N] IMAGE NAME

Options:
	--vm	Create the instance as a virtual machine.
	-t, --type	Set instance type passed to lxc init.
	-c, --cpus	Set CPU limit passed as -c limits.cpu=N.
	-m, --mem	Set memory limit passed as -c limits.memory=NGiB.
	--path SOURCE:TARGET	Add a bind mount from SOURCE to TARGET. May be repeated.
	--no-default-paths	Ignore shared_paths from ~/.local/config/lxc-launch-with-dirs.conf.
	-d, --disk-size	Set VM root disk size in GiB (default: 20).
	-h, --help	Show this help text.
EOF
}

CONFIG_FILE="$HOME/.local/config/lxc-launch-with-dirs.conf"
LXC_OPTS=()
PATH_OPTS=()
USE_DEFAULT_PATHS=true
IS_VM=false
DISK_SIZE=20

load_default_paths() {
	[[ -f "$CONFIG_FILE" ]] || return 0

	if ! command -v crudini >/dev/null 2>&1; then
		echo "Error: crudini is required to read $CONFIG_FILE" >&2
		exit 1
	fi

	shared_paths=$(crudini --get "$CONFIG_FILE" DEFAULT shared_paths 2>/dev/null || true)
	[[ -n "$shared_paths" ]] || return 0

	while IFS= read -r raw_item; do
		item="${raw_item#${raw_item%%[![:space:]]*}}"
		item="${item%${item##*[![:space:]]}}"
		[[ -n "$item" ]] || continue
		case "$item" in
			\#*|\;*)
				continue
				;;
		esac
		if [[ "$item" != *:* ]]; then
			echo "Error: invalid shared_paths entry: $item" >&2
			exit 1
		fi
		source="${item%%:*}"
		target="${item#*:}"
		source="${source/#\~/$HOME}"
		target="${target/#\~/$HOME}"
		source="${source//\$HOME/$HOME}"
		target="${target//\$HOME/$HOME}"
		echo "$source:$target"
	done <<< "$shared_paths"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)
			print_usage
			exit 0
			;;
		--vm)
			LXC_OPTS+=("--vm")
			IS_VM=true
			shift
			;;
		--no-default-paths)
			USE_DEFAULT_PATHS=false
			shift
			;;
		-t|--type)
			if [[ -z "$2" || "$2" == -* ]]; then
				echo "Error: $1 requires a value" >&2
				print_usage
				exit 1
			fi
			LXC_OPTS+=("--type" "$2")
			shift 2
			;;
		-c|--cpus)
			if [[ -z "$2" || "$2" == -* ]]; then
				echo "Error: $1 requires a value" >&2
				print_usage
				exit 1
			fi
			if ! [[ "$2" =~ ^[0-9]+$ ]]; then
				echo "Error: $1 value must be a non-negative integer" >&2
				exit 1
			fi
			LXC_OPTS+=("-c" "limits.cpu=$2")
			shift 2
			;;
		-m|--mem)
			if [[ -z "$2" || "$2" == -* ]]; then
				echo "Error: $1 requires a value" >&2
				print_usage
				exit 1
			fi
			if ! [[ "$2" =~ ^[0-9]+$ ]]; then
				echo "Error: $1 value must be a non-negative integer" >&2
				exit 1
			fi
			LXC_OPTS+=("-c" "limits.memory=${2}GiB")
			shift 2
			;;
		--path)
			if [[ -z "$2" || "$2" == -* ]]; then
				echo "Error: $1 requires a value" >&2
				print_usage
				exit 1
			fi
			if [[ "$2" != *:* ]]; then
				echo "Error: $1 value must use SOURCE:TARGET" >&2
				exit 1
			fi
			PATH_OPTS+=("$2")
			shift 2
			;;
		-d|--disk-size)
			if [[ -z "$2" || "$2" == -* ]]; then
				echo "Error: $1 requires a value" >&2
				print_usage
				exit 1
			fi
			if ! [[ "$2" =~ ^[0-9]+$ ]]; then
				echo "Error: $1 value must be a non-negative integer" >&2
				exit 1
			fi
			DISK_SIZE="$2"
			shift 2
			;;
		--)
			shift
			break
			;;
		*)
			break
			;;
	esac
done

if [[ $# -lt 2 ]]; then
	print_usage
	exit 0
fi

IMAGE="$1"
NAME="$2"

if $USE_DEFAULT_PATHS; then
	while IFS= read -r PATH_SPEC; do
		PATH_OPTS+=("$PATH_SPEC")
	done < <(load_default_paths)
fi

if $IS_VM; then
	LXC_OPTS+=("-d" "root,size=${DISK_SIZE}GiB")
fi

lxc init "${LXC_OPTS[@]}" "$IMAGE" "$NAME"

if ! $IS_VM; then
	lxc config set "$NAME" security.idmap.isolated true
	lxc config set "$NAME" security.idmap.size 65536 # Or a suitable size
fi

printf "uid $(id -u) 1000\ngid $(id -g) 1000" | lxc config set "$NAME" raw.idmap -

INDEX=1
for PATH_SPEC in "${PATH_OPTS[@]}"; do
	SOURCE=$(realpath "${PATH_SPEC%%:*}")
	TARGET="${PATH_SPEC#*:}"
    SHARE_NAME="$(basename $SOURCE)-$INDEX"
	lxc config device add "$NAME" $SHARE_NAME disk source="$SOURCE" path="$TARGET"
	INDEX=$((INDEX + 1))
done

lxc start "$NAME"
